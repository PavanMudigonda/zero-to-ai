language = "python3"
run = "jupyter notebook --ip=0.0.0.0 --port=8080 --no-browser --allow-root"

[nix]
channel = "stable-22_11"

[deployment]
run = ["sh", "-c", "jupyter notebook --ip=0.0.0.0 --port=8080 --no-browser --allow-root"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8080
externalPort = 80
